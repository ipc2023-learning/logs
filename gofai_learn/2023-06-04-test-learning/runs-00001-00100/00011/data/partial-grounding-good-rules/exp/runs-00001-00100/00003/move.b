%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% modes:
:- discontiguous('ini:at-robby'/2).
:- discontiguous('goal:at-robby'/2).
:- modeb(*, 'ini:at-robby'(+'type:object', +task_id)).
:- modeb(*, 'goal:at-robby'(+'type:object', +task_id)).
:- discontiguous('ini:at'/3).
:- discontiguous('goal:at'/3).
:- modeb(*, 'ini:at'(+'type:object', -'type:object', +task_id)).
:- modeb(*, 'goal:at'(+'type:object', -'type:object', +task_id)).
:- modeb(*, 'ini:at'(-'type:object', +'type:object', +task_id)).
:- modeb(*, 'goal:at'(-'type:object', +'type:object', +task_id)).
:- discontiguous('ini:free'/2).
:- discontiguous('goal:free'/2).
:- modeb(*, 'ini:free'(+'type:object', +task_id)).
:- modeb(*, 'goal:free'(+'type:object', +task_id)).
:- discontiguous('ini:carry'/3).
:- discontiguous('goal:carry'/3).
:- modeb(*, 'ini:carry'(+'type:object', -'type:object', +task_id)).
:- modeb(*, 'goal:carry'(+'type:object', -'type:object', +task_id)).
:- modeb(*, 'ini:carry'(-'type:object', +'type:object', +task_id)).
:- modeb(*, 'goal:carry'(-'type:object', +'type:object', +task_id)).

% types and constants

:- modeh(1, class(+'type:object', +'type:object', +task_id)).

